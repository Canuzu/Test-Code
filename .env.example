# Backend (Phase 1: accounts + cloud sync) — OPTIONAL.
#
# Leave these unset and the app runs fully local (local-only accounts, no sync),
# exactly as before. Set both to switch the SAME UI to real Supabase accounts
# with cross-device sync. See docs/BACKEND.md for the full setup.
#
# Local dev:  copy to ".env.local" and fill in.
# Deploy:     add these as repo Variables (or Secrets) and pass them to the
#             "npm run build" step's env in .github/workflows/deploy.yml.
#
# Values come from Supabase → Project Settings → API. The anon key is a public,
# RLS-protected client key (safe to ship in the frontend bundle).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Billing (Phase 2: Stripe subscription) — OPTIONAL. Empty = the app stays free
# for everyone (no gating). Set the price id (Stripe → Products → Price, "price_…")
# to turn the Pro features into a real subscription. The label is just display
# text (Stripe holds the real amount), e.g. "9 € / Monat".
VITE_STRIPE_PRICE_ID=
VITE_STRIPE_PRICE_LABEL=

# Live prices (Phase 3) — OPTIONAL. "true" enables the on-demand "live price"
# button (needs the 'prices' Edge Function deployed + Supabase configured).
VITE_LIVE_PRICES=

# Analytics (OPTIONAL) — privacy-friendly, cookieless, off unless set. We only
# send a coarse virtual path (e.g. "/pokemon/discover"), never card names or IDs.
# NB: if you enable this, add a sentence about it to the privacy policy.
# Pick ONE provider:
#   Plausible:   VITE_ANALYTICS_PROVIDER=plausible
#                VITE_ANALYTICS_DOMAIN=deine-domain.de
#   GoatCounter: VITE_ANALYTICS_PROVIDER=goatcounter
#                VITE_ANALYTICS_GC_URL=https://DEINCODE.goatcounter.com/count
VITE_ANALYTICS_PROVIDER=
VITE_ANALYTICS_DOMAIN=
VITE_ANALYTICS_GC_URL=
