# Backend (Phase 1: accounts + cloud sync) — OPTIONAL.
#
# Leave these unset and the app runs fully local (local-only accounts, no sync),
# exactly as before. Set both to switch the SAME UI to real Supabase accounts
# with cross-device sync. See docs/BACKEND.md for the full setup.
#
# Local dev:  copy to ".env.local" and fill in.
# Deploy:     add these as repo Variables (or Secrets) and pass them to the
#             "npm run build" step's env in .github/workflows/deploy.yml.
#
# Values come from Supabase → Project Settings → API. The anon key is a public,
# RLS-protected client key (safe to ship in the frontend bundle).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
